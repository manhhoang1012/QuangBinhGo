# App
APP_NAME=QuangBinhGo
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
AUTO_CREATE_TABLES=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quangbinhgo
POSTGRES_USER=quangbinhgo
POSTGRES_PASSWORD=quangbinhgo
DATABASE_URL=postgresql+psycopg://quangbinhgo:quangbinhgo@localhost:5432/quangbinhgo

# Security
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=quangbinhgo-review-posts

# AI
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2
